FROM ubuntu:24.04

RUN apt-get update -y && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        curl wget ca-certificates git python3 python3-pip python3-pytest bash ripgrep && \
    pip3 install --break-system-packages \
        pytest-json-ctrf \
        lancedb==0.25.3 \
        pyarrow==17.0.0 \
        numpy==1.26.4 \
        pandas==2.2.3 \
        polars==1.20.0 && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN mkdir -p /home/user && chmod 0755 /home/user
RUN mkdir -p /home/user/myproject

LABEL Author="generate-harbor-tasks"
LABEL Description="LanceDB + polars ingestion task: ingest a polars DataFrame into LanceDB via Arrow and run hybrid vector+SQL search."

CMD ["/bin/bash", "-c", "trap : TERM INT; sleep infinity & wait"]

# Container contents:
#   - always required apt packages: curl wget ca-certificates git python3 python3-pip python3-pytest bash ripgrep
#   - always required pip3 packages: pytest-json-ctrf
#   - lancedb==0.25.3 (target library) plus pyarrow==17.0.0, numpy==1.26.4, pandas==2.2.3 (LanceDB query.to_pandas dependency)
#   - polars==1.20.0 (DataFrame source feeding the Arrow ingestion roundtrip)
#   - /home/user/myproject: project directory (empty - candidate creates solution.py and lancedb/)
